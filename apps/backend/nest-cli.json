{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "apps/backend/src/main",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [{ "include": "../static/**/*", "outDir": "dist/apps/backend" }],
    "watchAssets": true
  }
}
