{
  "name": "@ratio-app/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm pixel:build:all && nest build",
    "dev": "pnpm pixel:build:all && nest start --watch",
    "start": "node dist/apps/backend/src/main.js",
    "typecheck": "tsc --noEmit && tsc -p pixel/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "pixel:build:all": "tsc -p pixel/tsconfig.json",
    "pixel:watch": "tsc -p pixel/tsconfig.json --watch"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.726.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@ratio-app/shared": "workspace:*",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "google-auth-library": "^10.7.0",
    "ioredis": "^5.4.2",
    "kysely": "^0.29.2",
    "mongodb": "^7.5.0",
    "mysql2": "^3.22.3",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/testing": "^11.1.24",
    "@swc/core": "^1.15.40",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.7"
  }
}
